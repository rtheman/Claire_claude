# Copy this file to .env and fill in real values.
# NEVER commit .env — it is gitignored.

# ── Google OAuth ─────────────────────────────────────────────────────────────
# Paths to your Google OAuth client secret and refresh token.
# Generate credentials.json from Google Cloud Console (OAuth 2.0 Client ID).
# Generate token.json by running: python .claude/skills/gmail-invoice/scripts/auth_google.py
GOOGLE_CREDENTIALS_PATH=auth/credentials.json
GOOGLE_TOKEN_PATH=auth/token.json

# ── API trigger (optional, VPS deployment only) ───────────────────────────────
# A secret token used to authenticate POST /run-invoice requests.
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
API_SECRET_TOKEN=your-secret-token-here

# ── Add further keys below as new Skills are added ───────────────────────────
